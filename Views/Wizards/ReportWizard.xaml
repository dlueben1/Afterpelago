<UserControl x:Class="AfterpelagoWPF.Views.ReportWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Step indicator circle styles -->
        <Style x:Key="StepCircleActive" TargetType="Ellipse">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Fill" Value="{DynamicResource MahApps.Brushes.Accent}" />
        </Style>
        <Style x:Key="StepCircleInactive" TargetType="Ellipse">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Fill" Value="#CCCCCC" />
        </Style>
        <Style x:Key="StepNumberActive" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepNumberInactive" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="StepLabelActive" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="StepLabelInactive" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <!-- Warning icon tooltip style for unsupported games -->
        <DataTemplate x:Key="GameItemTemplate">
            <Border Padding="12,8"
                    Margin="0,2"
                    Background="#0A000000"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status icon -->
                    <Grid Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0">
                        <!-- Supported: checkmark -->
                        <iconPacks:PackIconBoxIcons Kind="RegularCheckCircle"
                                                    Width="20" Height="20"
                                                    Foreground="#4CAF50"
                                                    Visibility="{Binding IsSupported, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="Game data found locally." />
                        <!-- Unsupported: warning -->
                        <iconPacks:PackIconMaterial Kind="Alert"
                                                    Width="20" Height="20"
                                                    Foreground="#FF9800"
                                                    Visibility="{Binding NeedsConfiguration, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    ToolTip="Game data not found. Report will have limited information for this game unless you provide an .apworld and .zip file." />
                    </Grid>

                    <!-- Game name and status -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameName}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray2}" />
                    </StackPanel>

                    <!-- File pick buttons for unsupported games -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding NeedsConfiguration, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Button Content=".apworld"
                                Padding="8,4"
                                Margin="4,0"
                                Tag="{Binding}"
                                Click="OnBrowseApWorld"
                                ToolTip="Select an .apworld file for this game" />
                        <Button Content=".zip"
                                Padding="8,4"
                                Margin="4,0"
                                Tag="{Binding}"
                                Click="OnBrowseZip"
                                ToolTip="Select a .zip data file for this game" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   FontFamily="Segoe UI"
                   FontSize="30"
                   FontWeight="Light"
                   Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                   Text="New Report"
                   Margin="0,0,0,16" />

        <!-- Step Indicator -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,24">
            <!-- Step 1 -->
            <StackPanel Orientation="Horizontal">
                <Grid>
                    <Ellipse x:Name="Step1Circle"
                             Style="{StaticResource StepCircleActive}" />
                    <TextBlock Text="1"
                               x:Name="Step1Number"
                               Style="{StaticResource StepNumberActive}" />
                </Grid>
                <TextBlock Text="Select Files"
                           x:Name="Step1Label"
                           Style="{StaticResource StepLabelActive}" />
            </StackPanel>

            <!-- Connector line -->
            <Rectangle Width="60"
                       Height="2"
                       Fill="{StaticResource MahApps.Brushes.Gray2}"
                       VerticalAlignment="Center"
                       Margin="16,0" />

            <!-- Step 2 -->
            <StackPanel Orientation="Horizontal">
                <Grid>
                    <Ellipse x:Name="Step2Circle"
                             Fill="{StaticResource MahApps.Brushes.Gray2}"
                             Style="{StaticResource StepCircleInactive}" />
                    <TextBlock Text="2"
                               x:Name="Step2Number"
                               Style="{StaticResource StepNumberInactive}" />
                </Grid>
                <TextBlock Text="Review Games"
                           x:Name="Step2Label"
                           Foreground="{StaticResource MahApps.Brushes.Gray2}"
                           Style="{StaticResource StepLabelInactive}" />
            </StackPanel>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="2"
                   Margin="0,0,0,16" />

        <!-- Step Content Area -->
        <Grid Grid.Row="3">
            <!-- STEP 1: Select Files -->
            <StackPanel x:Name="Step1Content"
                        Visibility="Visible">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                           Text="Log File"
                           Margin="0,0,0,8" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource MahApps.Brushes.Gray2}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="Select the Archipelago server log file. This file is required to generate a report." />
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="LogFilePathTextBox"
                             Grid.Column="0"
                             IsReadOnly="True"
                             Padding="8,6"
                             FontSize="13"
                             mah:TextBoxHelper.Watermark="No log file selected..."
                             Background="#F5F5F5" />
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Padding="16,6"
                            Margin="8,0,0,0"
                            Click="OnBrowseLogFile" />
                </Grid>

                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                           Text="Spoiler Log (Optional)"
                           Margin="0,0,0,8" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource MahApps.Brushes.Gray2}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="Optionally select a spoiler log. This provides extra context for the report but is not required." />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SpoilerFilePathTextBox"
                             Grid.Column="0"
                             IsReadOnly="True"
                             Padding="8,6"
                             FontSize="13"
                             mah:TextBoxHelper.Watermark="No spoiler log selected..."
                             Background="#F5F5F5" />
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Padding="16,6"
                            Margin="8,0,0,0"
                            Click="OnBrowseSpoilerFile" />
                </Grid>
            </StackPanel>

            <!-- STEP 2: Review Games -->
            <Grid x:Name="Step2Content"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="14"
                           Foreground="{DynamicResource MahApps.Brushes.Gray2}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Text="The following games were found in the log file. Games marked with a warning icon are not locally supported - you can optionally provide files to get richer report data." />

                <ListBox Grid.Row="1"
                         x:Name="GamesListBox"
                         ItemTemplate="{StaticResource GameItemTemplate}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.ScrollUnit="Pixel" />
            </Grid>
        </Grid>

        <!-- Bottom Navigation Bar -->
        <Grid Grid.Row="4"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Content="Back"
                    Padding="20,8"
                    Click="OnBack" />

            <Button x:Name="ImportButton"
                    Grid.Column="2"
                    Content="Import"
                    Padding="20,8"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="OnImport"
                    Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}" />

            <Button x:Name="GenerateButton"
                    Grid.Column="3"
                    Content="Generate"
                    Padding="20,8"
                    IsEnabled="False"
                    Click="OnGenerate"
                    Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}" />
        </Grid>
    </Grid>
</UserControl>
