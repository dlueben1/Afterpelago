<mah:MetroWindow x:Class="AfterpelagoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AfterpelagoWPF"
        mc:Ignorable="d"
        Title="Afterpelago"
        TitleCharacterCasing="Normal"
        WindowState="Maximized"
        WindowTitleBrush="Transparent"
        Height="450" 
        Width="800">
    
    <!-- Gradient BG -->
    <Window.Background>
        <DrawingBrush Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>

                    <!-- 1) Base: dark diagonal wash (top-left -> bottom-right) -->
                    <GeometryDrawing Geometry="M0,0 L1,0 1,1 0,1 Z">
                        <GeometryDrawing.Brush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF186A90" Offset="0.00"/>
                                <GradientStop Color="#0A2838" Offset="0.75"/>
                                <GradientStop Color="#051016" Offset="1.00"/>
                            </LinearGradientBrush>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>

                    <!-- 2) Overlay: upper-left "emphasis" spotlight -->
                    <GeometryDrawing Geometry="M0,0 L1,0 1,1 0,1 Z">
                        <GeometryDrawing.Brush>
                            <RadialGradientBrush
                            Center="0.14,0.10"
                            GradientOrigin="0.14,0.10"
                            RadiusX="1.75" RadiusY="1.75">
                                <!-- teal highlight near the corner, fading out -->
                                <GradientStop Color="#E6176F98" Offset="0.00"/>
                                <GradientStop Color="#80176F98" Offset="0.25"/>
                                <GradientStop Color="#00176F98" Offset="0.60"/>
                            </RadialGradientBrush>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Background>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Content="File" Click="OnFileMenuClick">
                <Button.ContextMenu>
                    <ContextMenu x:Name="FileContextMenu">
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Button Content="Tools" Click="OnToolsMenuClick">
                <Button.ContextMenu>
                    <ContextMenu x:Name="ToolsContextMenu">
                        <MenuItem Header="Import Game Data">
                            <MenuItem Header="From Files" />
                            <MenuItem Header="From Web" />
                        </MenuItem>
                        <MenuItem Header="Configure Local Application Data">
                            <MenuItem Header="Archipelago" Click="OnConfigureArchipelago" />
                            <MenuItem Header="PopTracker" Click="OnConfigurePopTracker" />
                        </MenuItem>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Button Content="Debug" Click="OnDebugMenuClick">
                <Button.ContextMenu>
                    <ContextMenu x:Name="DebugContextMenu">
                        <MenuItem Header="Browse Local Application Data" Click="OnBrowseLocalApplications" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>
    
    <!-- Content Area -->
    <Grid>
        <!-- Landing Page -->
        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Create Post-Game Report" Margin="12" Height="32" Foreground="White" />
            <Button Content="View Post-Game Report" Margin="12" Height="32" Foreground="White" />
            <Button Content="Configure Afterpelago" Margin="12" Height="32" Foreground="White" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
